server:
  port: 8080
  # Set this to the URL your podcast app will use to reach this server.
  # For Docker: replace with your NAS / host IP or hostname.
  base_url: "http://your-nas-ip:8080"

storage:
  # Paths are relative to the working directory (/app inside Docker).
  # These default values match the docker-compose volume mounts.
  cache_dir: ./cache
  data_dir: ./data

defaults:
  # How often to re-fetch each feed's RSS (minutes).
  refresh_interval_minutes: 60

  # When true, new episodes are automatically queued for background download
  # after each feed refresh.
  auto_prefetch: false

  # Only prefetch episodes published within this many days.
  # Set to 0 for no age limit.
  prefetch_max_age_days: 30

  # Number of simultaneous background download workers.
  prefetch_concurrency: 2

backup:
  # Directory where backup files are stored.
  # Defaults to {data_dir}/backups when not set.
  # dir: ./data/backups

  # Maximum number of backups to keep. Oldest are removed when the limit is
  # exceeded. Set to 0 for unlimited retention.
  max_backups: 5

  # How often to automatically create a backup (minutes).
  # Set to 0 to disable scheduled backups (manual-only via POST /api/backups).
  interval_minutes: 0
